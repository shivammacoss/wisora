# ─────────────────────────────────────────────────────────────
# Wisora Backend — Environment Variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# ---- App ----
NODE_ENV=development                     # development | test | production
PORT=8080                                # HTTP port the server listens on
API_PREFIX=/api/v1                       # base path for all routes
CLIENT_URL=http://localhost:5173         # frontend origin (used for CORS + email links)

# ---- Database ----
MONGODB_URI=mongodb://localhost:27017/wisora

# ---- JWT / Auth ----
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_ACCESS_EXPIRES_IN=15m                # access token lifetime
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_REFRESH_EXPIRES_IN=7d                # refresh token lifetime
BCRYPT_SALT_ROUNDS=12

# ---- Payments: Razorpay (INR) ----
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# ---- Payments: Stripe (USD/EUR) ----
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# ---- Email (Nodemailer / SMTP) ----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false                        # true for 465, false for other ports
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
EMAIL_FROM="Wisora <no-reply@wisora.app>"

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=900000              # 15 minutes
RATE_LIMIT_MAX=100                       # max requests per window per IP

# ---- Logging ----
LOG_LEVEL=info                           # error | warn | info | http | debug
