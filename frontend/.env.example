# ─────────────────────────────────────────────────────────────
# Wisora Frontend — Environment Variables
# Copy to `.env`. Only variables prefixed with VITE_ are exposed to the client.
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API (versioned).
VITE_API_BASE_URL=http://localhost:8080/api/v1

# App metadata
VITE_APP_NAME=Wisora

# Payment public keys (publishable / non-secret only)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
